# Copy this file to .env and fill in the blanks:  cp .env.example .env
# .env is git-ignored. godotenv loads it at startup for the worker and server.
# Real environment variables always take precedence over .env.

# ---------------------------------------------------------------------------
# Temporal
# ---------------------------------------------------------------------------
# Host-based run (go run ./worker): use localhost:7233.
# Compose worker (docker compose up -d): temporal:7233 is set in compose env directly.
TEMPORAL_HOSTPORT="localhost:7233"

# ---------------------------------------------------------------------------
# Postgres — Temporal's persistence backend. Used ONLY by the docker-compose
# `postgres` + `temporal` services (auto-setup). Not read by the Go app.
# ---------------------------------------------------------------------------
POSTGRES_USER="temporal"
POSTGRES_PASSWORD="temporal"
POSTGRES_DB="temporal"

# ---------------------------------------------------------------------------
# LLM provider (selected by the llm_factory; the resolved env is read by the
# Dagger engine for both agents)
# ---------------------------------------------------------------------------
# LLM_PROVIDER picks the backend: "anthropic" (default), "openai" (also any
# OpenAI-compatible gateway), or "bedrock" (Amazon Bedrock via a LiteLLM proxy).
# AGENT_MODEL is the per-run model override; if empty the provider's own model
# env var (or a default) is used.
LLM_PROVIDER="bedrock"
LLM_BEDROCK_MODEL="nova-pro"

# --- anthropic (LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-opus-4-8"   # used when AGENT_MODEL is empty
# ANTHROPIC_BASE_URL=""               # optional Anthropic-compatible endpoint

# --- openai / OpenAI-compatible gateways (LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o"               # used when AGENT_MODEL is empty
# OPENAI_BASE_URL=""                  # set for OpenRouter / LiteLLM / local servers
# OPENAI_AZURE_VERSION=""             # only for Azure OpenAI deployments (API version)

# --- amazon bedrock via LiteLLM proxy (LLM_PROVIDER=bedrock) ---
# Dagger has no native Bedrock transport; the bundled LiteLLM proxy exposes your
# Bedrock model as an OpenAI-compatible API. It starts with the rest of the stack:
#     docker compose up -d            # litellm runs by default (no profile)
# The proxy's model_list is in litellm_config.yaml (model_name -> bedrock/<id>,
# drop_params: true). See docker-compose.yml and
# https://docs.dagger.io/reference/configuration/llm/#amazon-bedrock-via-litellm-proxy
#
# NETWORKING: the Dagger ENGINE — not the worker — makes the OpenAI-compatible
# call. The engine now runs as a compose service (tagger-dagger-engine) on the
# compose network, so "litellm" resolves correctly. Use the service name here.
LLM_BEDROCK_PROXY_URL="http://litellm:4000"
LLM_BEDROCK_MODEL="nova-pro"   # a model_name from litellm_config.yaml
#
# AUTH (required): the litellm image rejects every request that lacks an API key,
# and validates non-master keys against a DB we do NOT run. The fix is to set a
# master key and send the SAME value as the request key — the master-key path
# skips the DB. LLM_BEDROCK_PROXY_KEY (sent as OPENAI_API_KEY by the factory) and
# LITELLM_MASTER_KEY (below) MUST be identical. Use any "sk-"-prefixed string.
LLM_BEDROCK_PROXY_KEY="sk-tagger-local-dev"

# AWS credentials for the LiteLLM proxy's Bedrock calls (consumed by the
# docker-compose `litellm` service, NOT by this app directly).
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-west-2"
# Must equal LLM_BEDROCK_PROXY_KEY above. Consumed by the litellm container.
LITELLM_MASTER_KEY="sk-tagger-local-dev"

# ---------------------------------------------------------------------------
# LangSmith — deep LLM tracing of every model call. LiteLLM's native langsmith
# logger (success_callback/failure_callback in litellm_config.yaml) mirrors each
# request/response — prompts, completions, tokens, tool calls, latency — to
# LangSmith as real LLM runs. Consumed by the docker-compose `litellm` service,
# NOT by this app directly. Leave LANGSMITH_API_KEY empty to effectively disable
# the callback. Create a key at https://smith.langchain.com (Settings -> API Keys).
# NOTE: this sends actual prompt/response content (incl. the Jira/Confluence text
# the context agent reads) to LangSmith SaaS. Self-host LangSmith if that's a concern.
# ---------------------------------------------------------------------------
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="tagger-agents"
# Only for a self-hosted LangSmith instance; leave unset for SaaS. If you set this,
# also add it to the litellm service env in docker-compose.yml (see the note there).
# LANGSMITH_BASE_URL="http://localhost:1984"

# Dagger-level runaway guards (tool round-trips per agent attempt)
AGENT_MAX_LOOPS="25"          # coding agent
AGENT_CONTEXT_MAX_LOOPS="20"  # Atlassian context-gathering agent

# ---------------------------------------------------------------------------
# Dagger runner host
# ---------------------------------------------------------------------------
# Tells the Dagger SDK (and CLI) which engine to connect to. With the engine
# as a compose service, set this to the container name so the worker's Dagger
# CLI execs into it (via the mounted Docker socket) instead of auto-provisioning
# a new engine that has no LLM env vars configured.
#
# Required for `go run ./worker` (host dev mode). The compose worker service
# sets this in its own environment block and does not read it from .env.
_EXPERIMENTAL_DAGGER_RUNNER_HOST="docker-container://tagger-dagger-engine"

# ---------------------------------------------------------------------------
# Dagger observability (engine + container logs to the worker terminal)
# ---------------------------------------------------------------------------
# The worker runs on the HOST (go run ./worker) and connects to the Dagger
# engine with WithLogOutput(os.Stderr); the engine streams its progress to the
# worker's stderr. Two knobs make that stream useful (code defaults both OFF —
# set them here to turn observability on):
#
# DAGGER_VERBOSITY — how much detail the engine prints. 0 (code default) = span
#   names only; 3 (-vvv) surfaces span debug logs, i.e. the LLM message turns and
#   tool-call request/response bodies. Lower it if the terminal is too noisy.
DAGGER_VERBOSITY="3"
#
# OTEL_EXPORTER_OTLP_TRACES_LIVE — Dagger-specific flag. Any non-empty value
#   streams spans live (~100ms) instead of batching them until each span ends,
#   so a long LLM loop shows progress instead of looking frozen. Read at engine
#   telemetry init and propagated into the engine.
OTEL_EXPORTER_OTLP_TRACES_LIVE="1"
#
# DAGGER_CLOUD_TOKEN — publish the FULL run trace (every span: container execs,
#   the agent loop, LLM tool round-trips, timing) to Dagger Cloud for flow
#   analysis and run history. Purely token-driven: when the worker process has
#   this set, the Dagger session it opens uploads its traces automatically — no
#   code or engine change needed, because the worker is the process that drives
#   the engine and godotenv loads this from .env at worker startup. Get a token
#   from your Dagger Cloud org settings. Leave empty to keep traces local-only.
#   Complements LangSmith: Dagger Cloud shows the orchestration/flow graph;
#   LangSmith (via the litellm proxy) shows the LLM prompt/response/token detail.
DAGGER_CLOUD_TOKEN=""

# ---------------------------------------------------------------------------
# GitHub — worker-side only, never enters Temporal. GITHUB_TOKEN serves two roles:
#   1. clone / push / open-PR in the coding agent (needs WRITE scope), and
#   2. the read-only GitHub MCP server the context agent uses to fetch GitHub
#      issues/PRs/files a ticket references (read-only mode blocks writes whatever
#      the token's scopes). The GitHub MCP server attaches to the context agent
#      ONLY when GITHUB_TOKEN is set; with it empty the agent simply has no GitHub
#      tools (Jira/Confluence still work).
# ---------------------------------------------------------------------------
GITHUB_TOKEN=""
AGENT_SIMULATE_PR="true"      # set to "false" to hit the real GitHub PR API
# Image for the read-only GitHub MCP server stood up by the context agent.
GITHUB_MCP_IMAGE="ghcr.io/github/github-mcp-server"

# ---------------------------------------------------------------------------
# Container images
# ---------------------------------------------------------------------------
# Per-language workspace images (golang:1.23, python:3.12, ...) live in the
# agent registry (agent_registry/agents/), not here — they are selected by the
# detected/overridden language at runtime.
AGENT_GIT_IMAGE="alpine/git:latest"
ATLASSIAN_MCP_IMAGE="ghcr.io/sooperset/mcp-atlassian:latest"

# ---------------------------------------------------------------------------
# Atlassian (Jira + Confluence) — consumed by the read-only mcp-atlassian server.
# Tokens are injected into the MCP container as Dagger secrets; they never reach
# the LLM context or a Temporal payload.
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# ---------------------------------------------------------------------------
CONFLUENCE_URL=""
CONFLUENCE_USERNAME=""
CONFLUENCE_API_TOKEN=""
CONFLUENCE_SSL_VERIFY="false"


JIRA_URL=""
JIRA_USERNAME=""
JIRA_API_TOKEN=""
JIRA_SSL_VERIFY="false"

# ---------------------------------------------------------------------------
# HTTP trigger API (Gin server)
# ---------------------------------------------------------------------------
HTTP_ADDR=":8080"
# When "true", the auth middleware rejects any /v1 request lacking an
# Authorization header (the seam for real OAuth/JWT validation). Default off.
API_AUTH_REQUIRED="false"
